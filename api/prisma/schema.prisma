generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  professor
  aluno
}

enum ClassType {
  OC6
  OC1
}


enum BookingStatus {
  pending
  confirmed
  cancelled
}

enum ProductCategory {
  vestuario
  acessorio
  equipamento
  outro
}

// ─── Endereço ─────────────────────────────────────────────────────────────────

model Address {
  id           String    @id @default(cuid())
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users User[]
}

// ─── Usuário (aluno + professor unificados por role) ──────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(aluno)
  birthDate   DateTime?
  active      Boolean  @default(true)
  avatarUrl   String?

  phones      Phone[]
  address     Address? @relation(fields: [addressId], references: [id])
  addressId   String?

  bookings      Booking[]
  oc1Requests   Oc1Request[]
  notifications Notification[]

  passwordResetToken   String?
  passwordResetExpires DateTime?
  emailVerifyToken     String?
  emailVerified        Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Phone {
  id     String @id @default(cuid())
  number String
  label  String? // ex: celular, whatsapp
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

// ─── Aula ─────────────────────────────────────────────────────────────────────

model Lesson {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  classTime   String    // horário livre, ex: "06:00", "07:30"
  classType   ClassType
  maxSpots    Int       @default(6)
  active      Boolean   @default(true)
  notes       String?

  bookings    Booking[]
  oc1Requests Oc1Request[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, classTime, classType])
}

// ─── Agendamento OC6 ─────────────────────────────────────────────────────────

model Booking {
  id       String        @id @default(cuid())
  status   BookingStatus @default(confirmed)
  notes    String?

  user     User   @relation(fields: [userId], references: [id])
  userId   String
  lesson   Lesson @relation(fields: [lessonId], references: [id])
  lessonId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

// ─── Solicitação OC1 (aguarda confirmação do professor) ───────────────────────

model Oc1Request {
  id       String        @id @default(cuid())
  status   BookingStatus @default(pending)
  notes    String?

  user     User   @relation(fields: [userId], references: [id])
  userId   String
  lesson   Lesson @relation(fields: [lessonId], references: [id])
  lessonId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

// ─── Evento ───────────────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  name        String
  location    String
  startAt     DateTime
  endAt       DateTime
  notes       String?
  active      Boolean  @default(true)
  imageUrl    String?

  sponsors    Sponsor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id          String  @id @default(cuid())
  name        String
  contact     String?
  socialMedia String?
  whatsApp    String?

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
}

// ─── Shop / Produtos ──────────────────────────────────────────────────────────

model Product {
  id          String          @id @default(cuid())
  name        String
  category    ProductCategory
  description String?
  price       Decimal         @db.Decimal(10, 2)
  active      Boolean         @default(true)

  variants    ProductVariant[]
  images      ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  size      String?
  color     String?
  stock     Int     @default(0)
  sku       String?

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  order     Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

// ─── Notificações in-app ──────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  message   String
  read      Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  createdAt DateTime @default(now())
}

// ─── Fotos da Praia / Remadas ─────────────────────────────────────────────────

model BeachPhoto {
  id          String   @id @default(cuid())
  url         String
  caption     String?
  takenAt     DateTime @default(now())
  featured    Boolean  @default(false)

  createdAt DateTime @default(now())
}
