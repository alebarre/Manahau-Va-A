# ─── Banco de dados ───────────────────────────────────────────────────────────
# Em produção: copiar a "Internal Database URL" do PostgreSQL no Render
DATABASE_URL="postgresql://user:password@host:5432/manahau?schema=public"

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_longa_e_aleatoria_com_no_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL do frontend na Vercel (sem barra no final)
FRONTEND_URL=https://manahau.vercel.app

# ─── SMTP (email de verificação e reset de senha) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="Manahau Va'A <noreply@manahau.com.br>"

# ─── Cloudinary (upload de fotos) ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
